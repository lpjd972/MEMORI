# Copie ce fichier en "keystore.properties" (sans .example) et remplis-le.
# NE COMMITTE JAMAIS keystore.properties NI le fichier .keystore : ils sont
# secrets. Si tu perds le keystore, tu ne pourras plus mettre à jour l'app.

# Chemin vers ton keystore, relatif au dossier android/
storeFile=memori.keystore
storePassword=TON_MOT_DE_PASSE_STORE
keyAlias=memori
keyPassword=TON_MOT_DE_PASSE_CLE
